#!/bin/sh

echo "Running pre-commit checks..."

# Format
echo "  Checking formatting..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
    echo "ERROR: cargo fmt failed. Run 'cargo fmt --all' to fix."
    exit 1
fi

# Clippy
echo "  Running clippy..."
cargo clippy --workspace -- -D warnings
if [ $? -ne 0 ]; then
    echo "ERROR: clippy found warnings."
    exit 1
fi

# Tests
echo "  Running tests..."
cargo test --workspace --quiet
if [ $? -ne 0 ]; then
    echo "ERROR: tests failed."
    exit 1
fi

echo "All checks passed."
